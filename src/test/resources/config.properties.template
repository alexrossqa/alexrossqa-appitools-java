# Copy this file to config.properties and fill in your values.
# config.properties is gitignored — never commit your token.

# Your Plex Media Server URL
plex.url=http://localhost:32400

# Your Plex auth token.
# How to find it: Plex Web > any media item > ... > Get Info > View XML.
# The token appears in the URL as X-Plex-Token=...
plex.token=YOUR_PLEX_TOKEN_HERE

# Full URL of a film's detail page.
# How to find it: open any film in Plex in your browser and copy the address bar URL.
plex.film.url=http://localhost:32400/web/index.html#!/server/YOUR_MACHINE_ID/details?key=%2Flibrary%2Fmetadata%2FYOUR_RATING_KEY
